# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL plugin.
# Copy it from Railway dashboard → Variables → DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/ekorafon"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── URLs (set these to your deployed domain) ──────────────────────────────────
WEB_URL="https://ekorafon.netlify.app"
ADMIN_URL="https://admin.ekorafon.netlify.app"

# ── Paystack ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
# Webhook URL to register in Paystack dashboard:
#   https://your-railway-api-url.railway.app/api/payment/webhook

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at resend.com, add & verify your domain, then create an API key.
# If RESEND_API_KEY is not set, emails are logged to console only (safe for dev).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Ekorafon <noreply@ekorafon.com>"
